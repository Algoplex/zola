{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true
  },
  "rules": {
    "no-unused-vars": "warn",
    "eqeqeq": "error",
    "no-console": "off",
    "react-hooks/exhaustive-deps": "warn"
  },
  "ignorePatterns": ["node_modules/**", "dist/**", ".next/**", "drizzle/**"]
}
